{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals"]
  }
}
