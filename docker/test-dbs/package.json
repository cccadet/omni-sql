{
  "name": "@omni-sql/test-dbs",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "docker compose up -d",
    "stop": "docker compose down -v",
    "restart": "docker compose down -v && docker compose up -d",
    "test": "node --test --import ./smoke-test.ts",
    "test:integration": "OMNI_SQL_RUN_INTEGRATION=1 node --test --import ./integration-test.ts",
    "test:smoke": "OMNI_SQL_RUN_INTEGRATION=1 node --test --import ./smoke-test.ts",
    "test:pg": "OMNI_SQL_RUN_INTEGRATION=1 node --test --test-name-pattern=PostgreSQL --import ./smoke-test.ts",
    "test:mysql": "OMNI_SQL_RUN_INTEGRATION=1 node --test --test-name-pattern=MySQL --import ./smoke-test.ts",
    "test:mssql": "OMNI_SQL_RUN_INTEGRATION=1 node --test --test-name-pattern='SQL Server' --import ./smoke-test.ts",
    "test:oracle": "OMNI_SQL_RUN_INTEGRATION=1 node --test --test-name-pattern='Oracle XE' --import ./smoke-test.ts"
  },
  "dependencies": {
    "@omni-sql/backend": "workspace:*",
    "@omni-sql/adapters-core": "workspace:*",
    "@omni-sql/adapters-pg": "workspace:*",
    "@omni-sql/adapters-mysql": "workspace:*",
    "@omni-sql/adapters-mssql": "workspace:*",
    "@omni-sql/adapters-oracle": "workspace:*",
    "@omni-sql/ts-types": "workspace:*"
  }
}
